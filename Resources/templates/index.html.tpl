<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Swift Blog Carnival</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <header>
        <h1>Swift Blog Carnival</h1>
        <p>A monthly community blogging event for Swift developers.</p>
    </header>
    <main>
        {{FEATURED}}
        <h2>All Editions</h2>
        {{TABLE}}
        <section class="volunteer">
            <h2>Want to Host?</h2>
            <p>
                Fork <a href="https://github.com/SwiftCarnival/swiftcarnival.github.io">the repository</a>,
                add your edition to <code>data/editions.yml</code>, and open a pull request.
            </p>
        </section>
    </main>
    <footer>
        <p>Swift Blog Carnival is a community project. <a href="https://github.com/SwiftCarnival/swiftcarnival.github.io">Contribute on GitHub.</a></p>
    </footer>
</body>
</html>
